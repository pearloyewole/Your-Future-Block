# ----- Backend selection -----
# 'duckdb' (default, hackathon-friendly) or 'postgres'
RISKLENS_DB_BACKEND=duckdb

# ----- DuckDB -----
# Which DB the API serves. Flip between synthetic and real at any time --
# the API has no concept of pipelines, just file paths.
DUCKDB_PATH=backend/data/processed/risklens.synthetic.duckdb

# Per-pipeline write targets. The build scripts read these to know where
# to land their output. Leave at defaults unless you need a custom layout.
SYNTHETIC_DUCKDB_PATH=backend/data/processed/risklens.synthetic.duckdb
REAL_DUCKDB_PATH=backend/data/processed/risklens.real.duckdb

# ----- Postgres (used only when RISKLENS_DB_BACKEND=postgres) -----
DATABASE_URL=postgresql+psycopg://risklens:risklens@localhost:5432/risklens

# ----- Redis (response cache; optional) -----
REDIS_URL=redis://localhost:6379/0

# ----- Region of interest -----
ROI_NAME=la_county
ROI_BBOX=-119.0,33.5,-117.5,34.9       # minLon,minLat,maxLon,maxLat
H3_RESOLUTION=9                         # ~150m edge

# ----- External APIs -----
CENSUS_API_KEY=                         # https://api.census.gov/data/key_signup.html
CENSUS_GEOCODER_BASE=https://geocoding.geo.census.gov/geocoder

# ----- LLM for explanations -----
LLM_PROVIDER=anthropic                  # 'anthropic' | 'openai' | 'none'
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-3-5-sonnet-latest

# ----- Cal-Adapt LOCA2-Hybrid (S3 anonymous) -----
CALADAPT_S3_BUCKET=cadcat
CALADAPT_S3_PREFIX=loca2-hybrid

# ----- Logging -----
LOG_LEVEL=INFO
